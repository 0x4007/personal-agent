{
  "name": "plugin-template",
  "version": "1.0.0",
  "description": "Ubiquibot plugin template repository with TypeScript support.",
  "author": "Ubiquity DAO",
  "license": "MIT",
  "main": "src/index.ts",
  "type": "module",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "bundle": "tsup --config tsup.config.ts",
    "dev:local": "NODE_ENV=local bun scripts/local-run.ts",
    "dev:pi": "REAL_PI=1 NODE_ENV=local AGENT_OWNER=0x4007 OWNER=ubiquity REPO=.github-private ISSUE=23 BODY='@0x4007 local to pi' bun scripts/local-run.ts",
    "simulate": "bun scripts/simulate.ts",
    "format": "run-p format:*",
    "check-formatting": "run-p check-formatting:* format:cspell",
    "check-formatting:lint": "eslint --fix-dry-run",
    "format:lint": "eslint --fix .",
    "format:prettier": "prettier --write .",
    "check-formatting:prettier": "prettier --check .",
    "format:cspell": "cspell **/*",
    "knip": "knip --config .github/knip.ts",
    "knip-ci": "knip --no-exit-code --reporter json --config .github/knip.ts",
    "prepare": "husky install"
  },
  "keywords": [
    "typescript",
    "template",
    "dao",
    "ubiquity",
    "open-source"
  ],
  "dependencies": {
    "@sinclair/typebox": "^0.34.30",
    "@ubiquity-os/plugin-sdk": "^3.8.1",
    "@ubiquity-os/ubiquity-os-logger": "^1.4.0",
    "dotenv": "16.4.7"
  },
  "devDependencies": {
    "@commitlint/cli": "19.6.1",
    "@commitlint/config-conventional": "19.6.0",
    "@cspell/dict-node": "5.0.6",
    "@cspell/dict-software-terms": "4.2.4",
    "@cspell/dict-typescript": "3.2.0",
    "@eslint/js": "9.19.0",
    "@types/node": "22.12.0",
    "cspell": "8.17.3",
    "eslint": "9.19.0",
    "eslint-plugin-check-file": "3.0.0",
    "eslint-plugin-sonarjs": "3.0.1",
    "husky": "9.1.7",
    "knip": "5.43.6",
    "lint-staged": "15.4.3",
    "npm-run-all": "4.1.5",
    "prettier": "3.4.2",
    "tsup": "^8.5.0",
    "typescript": "5.6.2",
    "typescript-eslint": "8.22.0"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ],
    "src/**.{ts,json}": [
      "cspell"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
