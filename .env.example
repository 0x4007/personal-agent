# GitHub Configuration
PERSONAL_ACCESS_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
AGENT_OWNER=your-github-username

# Claude Configuration
CLAUDE_CODE_OAUTH_TOKEN=your_claude_token_here

# Access Control
ACCESS_MODE=full  # or "read-only" for limited access

# Platform Credentials
TELEGRAM_BOT_TOKEN=bot_token_from_botfather
DISCORD_BOT_TOKEN=discord_bot_token
SLACK_APP_TOKEN=slack_app_token


# Webhook Configuration
WEBHOOK_SECRET=webhook_verification_secret
API_ENDPOINT=https://api.personal-agent.com

# Monitoring (optional)
DATADOG_API_KEY=monitoring_key
SENTRY_DSN=sentry_error_tracking_dsn
LOG_LEVEL=info

# Environment
NODE_ENV=production
