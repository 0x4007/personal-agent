# Pre-push hook to trigger a Pi pull AFTER the push completes.
# We can't run post-push (Git lacks it), so we spawn a background watcher
# that waits until the new commit appears on the remote, then calls the
# LAN sync script to pull on the Pi.


[ -n "$CI" ] && exit 0
[ "$DISABLE_PI_AGENT_SYNC" = "1" ] && exit 0

# Hardcoded local path to your pi-agent clone on this machine
LOCAL_PI_AGENT_DIR="/Users/nv/repos/pi-agent"
REMOTE="origin"

# Validate repo exists
if [ ! -d "$LOCAL_PI_AGENT_DIR/.git" ]; then
  exit 0
fi

BRANCH=$(git -C "$LOCAL_PI_AGENT_DIR" rev-parse --abbrev-ref HEAD 2>/dev/null)
SHA=$(git -C "$LOCAL_PI_AGENT_DIR" rev-parse "$BRANCH" 2>/dev/null)

[ -z "$BRANCH" ] && exit 0
[ -z "$SHA" ] && exit 0

# Background watcher: poll remote until the pushed SHA is visible, then pull on Pi
(
  set -e
  # Wait up to ~2 minutes
  i=0
  while [ $i -lt 60 ]; do
    if git -C "$LOCAL_PI_AGENT_DIR" ls-remote "$REMOTE" "$BRANCH" 2>/dev/null | grep -q "$SHA"; then
      BRANCH="$BRANCH" PI_USER="pi" PI_HOST="pi.local" scripts/pi-agent-git.sh pull || true
      PI_USER="pi" PI_HOST="pi.local" scripts/pi-agent-git.sh restart || true
      exit 0
    fi
    sleep 2
    i=$((i+1))
  done
) >/dev/null 2>&1 &

exit 0
